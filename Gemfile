source 'https://rubygems.org'

# Mirrors GitHub Pages' built-in "Deploy from a branch" build so local output
# matches what GitHub generates: it pins Jekyll and the supported (whitelisted)
# plugins to the exact versions GitHub Pages uses. Requires Ruby >= 3.1.
gem 'github-pages', group: :jekyll_plugins

# WEBrick left Ruby's stdlib in 3.0+, so `jekyll serve` needs it explicitly.
gem 'webrick' # required on Ruby 3+
